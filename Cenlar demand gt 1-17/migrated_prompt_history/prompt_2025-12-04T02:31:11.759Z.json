      "type": "text",
      "text": "<!DOCTYPE html><html lang=\"en\"><head>\n<base href=\"https://afac7552bda22.ok.kimi.link\">\n    <meta charset=\"UTF-8\"/>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n    <title>FitConnect - Find Your Perfect Trainer at 50% Off</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js\"></script>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.7.0/p5.min.js\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css\"/>\n    <style>\n        body { font-family: 'Inter', sans-serif; }\n        .hero-bg { background: linear-gradient(135deg, #2D3748 0%, #4A5568 100%); }\n        .card-hover { transition: all 0.3s ease; }\n        .card-hover:hover { transform: translateY(-8px) rotateX(5deg); box-shadow: 0 20px 40px rgba(0,0,0,0.15); }\n        .floating { animation: float 6s ease-in-out infinite; }\n        @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-20px); } }\n        .gradient-text { background: linear-gradient(135deg, #FF6B6B, #68D391); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }\n        #particles-canvas { position: absolute; top: 0; left: 0; z-index: 1; }\n        .content-overlay { position: relative; z-index: 2; }\n    </style>\n<script src=\"https://statics.moonshot.cn/sdk/preview-widgets.min.js\" defer=\"\"></script></head>\n<body class=\"bg-gray-50\">\n    <!-- Navigation -->\n    <nav class=\"bg-white shadow-sm fixed w-full top-0 z-50\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"flex justify-between items-center h-16\">\n                <div class=\"flex items-center\">\n                    <div class=\"flex-shrink-0\">\n                        <h1 class=\"text-2xl font-bold gradient-text\">FitConnect</h1>\n                    </div>\n                </div>\n                <div class=\"hidden md:block\">\n                    <div class=\"ml-10 flex items-baseline space-x-4\">\n                        <a href=\"#\" class=\"text-gray-900 hover:text-red-400 px-3 py-2 rounded-md text-sm font-medium\">Find Trainers</a>\n                        <a href=\"#\" class=\"text-gray-900 hover:text-red-400 px-3 py-2 rounded-md text-sm font-medium\">How It Works</a>\n                        <a href=\"#\" class=\"text-gray-900 hover:text-red-400 px-3 py-2 rounded-md text-sm font-medium\">Safety</a>\n                        <button class=\"bg-red-400 text-white px-4 py-2 rounded-lg hover:bg-red-500 transition-colors\">Sign In</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </nav>\n\n    <!-- Hero Section -->\n    <section class=\"hero-bg relative min-h-screen flex items-center overflow-hidden\">\n        <canvas id=\"particles-canvas\"></canvas>\n        <div class=\"content-overlay max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 items-center\">\n                <div class=\"text-white\">\n                    <h1 class=\"text-5xl lg:text-6xl font-bold mb-6 leading-tight\">\n                        Find <span class=\"text-red-400\">Certified Trainers</span> at 50% Off Their Downtime\n                    </h1>\n                    <p class=\"text-xl mb-8 text-gray-200 leading-relaxed\">\n                        Connect with verified fitness professionals during their unused hours. Save money while getting premium training from certified experts in your area.\n                    </p>\n                    <div class=\"flex flex-col sm:flex-row gap-4\">\n                        <button onclick=\"scrollToSearch()\" class=\"bg-red-400 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-red-500 transition-all transform hover:scale-105\">\n                            Find Your Trainer\n                        </button>\n                        <button class=\"border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white hover:text-gray-900 transition-all\">\n                            How It Works\n                        </button>\n                    </div>\n                    <div class=\"mt-12 grid grid-cols-3 gap-8 text-center\">\n                        <div>\n                            <div class=\"text-3xl font-bold text-red-400\">10,000+</div>\n                            <div class=\"text-sm text-gray-300\">Verified Trainers</div>\n                        </div>\n                        <div>\n                            <div class=\"text-3xl font-bold text-green-400\">50% Off</div>\n                            <div class=\"text-sm text-gray-300\">Standard Rates</div>\n                        </div>\n                        <div>\n                            <div class=\"text-3xl font-bold text-blue-400\">24/7</div>\n                            <div class=\"text-sm text-gray-300\">Support</div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"relative\">\n                    <img src=\"resources/hero-gym.jpg\" alt=\"Modern Fitness Gym\" class=\"rounded-2xl shadow-2xl floating\"/>\n                    <div class=\"absolute -top-4 -right-4 bg-green-400 text-white px-4 py-2 rounded-lg font-semibold\">\n                        50% OFF\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Search Section -->\n    <section id=\"search-section\" class=\"py-20 bg-white\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"text-center mb-12\">\n                <h2 class=\"text-4xl font-bold text-gray-900 mb-4\">Find Your Perfect Trainer</h2>\n                <p class=\"text-xl text-gray-600\">Search by location, specialty, and availability</p>\n            </div>\n            \n            <!-- Search Filters -->\n            <div class=\"bg-gray-50 rounded-2xl p-8 mb-12\">\n                <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6\">\n                    <div>\n                        <label class=\"block text-sm font-medium text-gray-700 mb-2\">Location</label>\n                        <input type=\"text\" id=\"location-search\" placeholder=\"Enter your city or zip\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:border-transparent\"/>\n                    </div>\n                    <div>\n                        <label class=\"block text-sm font-medium text-gray-700 mb-2\">Training Type</label>\n                        <select id=\"specialty-filter\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:border-transparent\">\n                            <option value=\"\">All Specialties</option>\n                            <option value=\"strength\">Strength Training</option>\n                            <option value=\"cardio\">Cardio &amp; HIIT</option>\n                            <option value=\"yoga\">Yoga &amp; Pilates</option>\n                            <option value=\"nutrition\">Nutrition Coaching</option>\n                            <option value=\"rehab\">Injury Rehabilitation</option>\n                        </select>\n                    </div>\n                    <div>\n                        <label class=\"block text-sm font-medium text-gray-700 mb-2\">Price Range</label>\n                        <select id=\"price-filter\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-400 focus:border-transparent\">\n                            <option value=\"\">Any Price</option>\n                            <option value=\"budget\">$30-50/hour</option>\n                            <option value=\"standard\">$50-80/hour</option>\n                            <option value=\"premium\">$80+/hour</option>\n                        </select>\n                    </div>\n                    <div class=\"flex items-end\">\n                        <button onclick=\"searchTrainers()\" class=\"w-full bg-red-400 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-500 transition-colors\">\n                            Search Trainers\n                        </button>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Trainer Results -->\n            <div id=\"trainer-results\" class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <!-- Trainer cards will be populated by JavaScript -->\n            </div>\n        </div>\n    </section>\n\n    <!-- How It Works -->\n    <section class=\"py-20 bg-gray-50\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"text-center mb-16\">\n                <h2 class=\"text-4xl font-bold text-gray-900 mb-4\">How FitConnect Works</h2>\n                <p class=\"text-xl text-gray-600\">Three simple steps to premium fitness at half the price</p>\n            </div>\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12\">\n                <div class=\"text-center\">\n                    <div class=\"bg-red-400 w-16 h-16 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-6\">1</div>\n                    <h3 class=\"text-2xl font-semibold mb-4\">Search &amp; Discover</h3>\n                    <p class=\"text-gray-600\">Browse verified trainers in your area with transparent pricing and availability during their downtime hours.</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"bg-green-400 w-16 h-16 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-6\">2</div>\n                    <h3 class=\"text-2xl font-semibold mb-4\">Book &amp; Confirm</h3>\n                    <p class=\"text-gray-600\">Instantly book discounted sessions with secure payment and automatic confirmation from your chosen trainer.</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"bg-blue-400 w-16 h-16 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-6\">3</div>\n                    <h3 class=\"text-2xl font-semibold mb-4\">Train &amp; Rate</h3>\n                    <p class=\"text-gray-600\">Enjoy your session with GPS check-in, then rate your experience and optionally continue at standard rates.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Trust &amp; Safety -->\n    <section class=\"py-20 bg-white\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"text-center mb-16\">\n                <h2 class=\"text-4xl font-bold text-gray-900 mb-4\">Trust &amp; Safety First</h2>\n                <p class=\"text-xl text-gray-600\">Every trainer is thoroughly verified for your peace of mind</p>\n            </div>\n            <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\">\n                <div class=\"text-center p-6 bg-gray-50 rounded-xl\">\n                    <div class=\"text-4xl mb-4\">✓</div>\n                    <h3 class=\"text-lg font-semibold mb-2\">Background Checks</h3>\n                    <p class=\"text-gray-600 text-sm\">Comprehensive criminal background screening</p>\n                </div>\n                <div class=\"text-center p-6 bg-gray-50 rounded-xl\">\n                    <div class=\"text-4xl mb-4\">🏆</div>\n                    <h3 class=\"text-lg font-semibold mb-2\">Certification Verification</h3>\n                    <p class=\"text-gray-600 text-sm\">NASM, ACE, ACSM, and other accredited certifications</p>\n                </div>\n                <div class=\"text-center p-6 bg-gray-50 rounded-xl\">\n                    <div class=\"text-4xl mb-4\">🛡️</div>\n                    <h3 class=\"text-lg font-semibold mb-2\">Insurance Coverage</h3>\n                    <p class=\"text-gray-600 text-sm\">Professional liability insurance verification</p>\n                </div>\n                <div class=\"text-center p-6 bg-gray-50 rounded-xl\">\n                    <div class=\"text-4xl mb-4\">⭐</div>\n                    <h3 class=\"text-lg font-semibold mb-2\">Client Reviews</h3>\n                    <p class=\"text-gray-600 text-sm\">Transparent rating system with detailed feedback</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Featured Trainers Carousel -->\n    <section class=\"py-20 bg-gray-50\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"text-center mb-16\">\n                <h2 class=\"text-4xl font-bold text-gray-900 mb-4\">Featured Trainers</h2>\n                <p class=\"text-xl text-gray-600\">Top-rated professionals with available downtime slots</p>\n            </div>\n            <div class=\"splide\" id=\"trainer-carousel\">\n                <div class=\"splide__track\">\n                    <ul class=\"splide__list\" id=\"featured-trainers\">\n                        <!-- Featured trainer cards will be populated by JavaScript -->\n                    </ul>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-white py-12\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"text-center\">\n                <h3 class=\"text-2xl font-bold gradient-text mb-4\">FitConnect</h3>\n                <p class=\"text-gray-400 mb-6\">Connecting fitness professionals with clients during their downtime</p>\n                <div class=\"text-sm text-gray-500\">\n                    © 2024 FitConnect. All rights reserved. | Privacy Policy | Terms of Service\n                </div>\n            </div>\n        </div>\n    </footer>\n\n    <script src=\"main.js\"></script>\n\n</body></html>",
